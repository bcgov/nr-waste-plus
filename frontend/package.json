{
  "name": "nr-waste-plus-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint ./src --ext .ts,.tsx",
    "stub": "dotenv -- wiremock --enable-stub-cors --global-response-templating --port 8080 --https-port 8181 --root-dir ./stub --verbose --permitted-system-keys=\"VITE_USER_POOLS_WEB_CLIENT_ID\"",
    "stub:login": "dotenv -- wiremock --enable-stub-cors --global-response-templating --port 8180 --https-port 8181 --root-dir ./stub --verbose --permitted-system-keys=\"VITE_USER_POOLS_WEB_CLIENT_ID\"",
    "preview": "npm run dev & npm run stub",
    "test:unit": "vitest run --coverage --allowOnly --maxWorkers=2",
    "test:unit:watch": "vitest --allowOnly",
    "pree2e": "echo '{}' > src/config/tests/user.bceid.json && echo '{}' > src/config/tests/user.idir.json",
    "serve:e2e": "vite preview",
    "serve:e2e:test": "cross-env VITE_MOCK_AUTH=true npm run build && npm run serve:e2e",
    "pw:install": "playwright install-deps && playwright install",
    "pretest:e2e": "node -e \"if (!process.env.CI) require('child_process').execSync('npm run pw:install', {stdio:'inherit'})\" && npm run pree2e",
    "pretest:e2e:watch": "npm run pw:install && npm run pree2e",
    "test:e2e": "cross-env VITE_MOCK_AUTH=true playwright test",
    "test:e2e:watch": "cross-env VITE_MOCK_AUTH=true playwright test --ui",
    "pretest:e2e:bceid": "node -e \"if (!process.env.CI) require('child_process').execSync('npm run pw:install', {stdio:'inherit'})\" && npm run pree2e",
    "test:e2e:bceid": "cross-env VITE_MOCK_AUTH=true VITE_COVERAGE=true playwright test --project=bceid-setup --project=bceid-chromium",
    "pretest:e2e:idir": "node -e \"if (!process.env.CI) require('child_process').execSync('npm run pw:install', {stdio:'inherit'})\" && npm run pree2e",
    "test:e2e:idir": "cross-env VITE_MOCK_AUTH=true VITE_COVERAGE=true playwright test --project=idir-setup --project=idir-chromium",
    "pretest:a11y": "cross-env RUN_A11Y_TESTS=true npm run pretest:coverage",
    "pretest:a11y:watch": "playwright install chromium",
    "test:a11y": "cross-env RUN_A11Y_TESTS=true playwright test --project=a11y-chromium",
    "test:a11y:watch": "playwright test --project=a11y-chromium --ui",
    "pretest:coverage": "echo '{}' > src/config/tests/user.bceid.json && echo '{}' > src/config/tests/user.idir.json",
    "test:coverage": "npm run test:unit; UNIT=$?; npm run test:e2e; E2E=$?; exit $((UNIT||E2E))",
    "coverage:merge": "mkdir -p .nyc_output && cp coverage/coverage-final.json .nyc_output/unit-coverage.json && nyc merge .nyc_output .nyc_output/coverage.json && nyc report --reporter=lcov --reporter=text-summary --report-dir=coverage",
    "posttest:coverage": "npm run coverage:merge"
  },
  "dependencies": {
    "@bcgov-nr/nr-theme": "^1.8.9",
    "@carbon/icons-react": "^11.76.0",
    "@carbon/pictograms-react": "^11.97.0",
    "@carbon/react": "^1.103.0",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-router": "^1.169.2",
    "aws-amplify": "^6.18.0",
    "axios": "^1.15.2",
    "exceljs": "^4.4.0",
    "idb": "^8.0.3",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "pretty-bytes": "^7.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "1.61.1",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-form-devtools": "^0.2.27",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.23",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.20",
    "axe-core": "^4.11.1",
    "axe-playwright": "^2.2.2",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.0.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^17.0.0",
    "nyc": "^18.0.0",
    "playwright": "1.61.1",
    "prettier": "^3.7.4",
    "sass": "^1.98.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.52.0",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "wiremock": "^3.13.2"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "immutable": "^5.1.5",
    "serialize-javascript": "^7.0.5",
    "rollup": "^4.54.0",
    "workbox-build": {
      "glob": "^13.0.0"
    },
    "nyc": {
      "glob": "^13.0.0"
    },
    "test-exclude": {
      "glob": "^13.0.0"
    },
    "rimraf": {
      "glob": "^13.0.0"
    },
    "@eslint/eslintrc": {
      "js-yaml": "4.2.0"
    },
    "@aws-amplify/core": {
      "uuid": "^11.1.1"
    },
    "exceljs": {
      "uuid": "^11.1.1"
    }
  },
  "nyc": {
    "reporter": [
      "lcov",
      "text-summary"
    ],
    "report-dir": "coverage",
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ],
    "exclude": [
      "**/*.spec.ts",
      "**/__tests__/**",
      "**/__e2e__/**"
    ],
    "extension": [
      ".ts",
      ".tsx"
    ]
  }
}
