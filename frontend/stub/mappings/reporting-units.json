    {
      "name": "Create reporting unit — DKM missing grade code",
      "request": {
        "urlPath": "/api/reporting-units",
        "method": "POST",
        "bodyPatterns": [
          { "matchesJsonPath": "$.districtCode", "equalTo": "DKM" },
          {
            "matchesJsonPath": "$[?(@.gradeCode == '' || @.gradeCode == null || !@.gradeCode)]"
          }
        ]
      },
      "response": {
        "status": 400,
        "headers": { "Content-Type": "application/json" },
        "body": "{\"message\": \"Grade code is required for district DKM\"}"
      },
      "priority": 1
