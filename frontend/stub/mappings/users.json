{
  "mappings": [
    {
      "name": "Preferences IDIR user",
      "request": {
        "url": "/api/users/preferences",
        "method": "GET",
        "cookies": {
          "CognitoIdentityServiceProvider.{{systemValue key='VITE_USER_POOLS_WEB_CLIENT_ID'}}.LastAuthUser": {
            "equalTo": "idirUser"
          }
        }
      },
      "response": {
        "status": 200,
        "bodyFileName": "users/preferences-GET-idir-1.json"
      }
    },
    {
      "name": "Preferences BCeID user",
      "request": {
        "url": "/api/users/preferences",
        "method": "GET",
        "cookies": {
          "CognitoIdentityServiceProvider.{{systemValue key='VITE_USER_POOLS_WEB_CLIENT_ID'}}.LastAuthUser": {
            "equalTo": "bceidUser"
          }
        }
      },
      "response": {
        "status": 200,
        "bodyFileName": "users/preferences-GET-bceid-1.json"
      }
    },
    {
      "name": "Bookmark a reporting unit",
      "request": {
        "urlPathPattern": "/api/users/bookmarks/[0-9]+",
        "method": "PUT"
      },
      "response": {
        "status": 202
      }
    },
    {
      "name": "Remove a bookmarked reporting unit",
      "request": {
        "urlPathPattern": "/api/users/bookmarks/[0-9]+",
        "method": "DELETE"
      },
      "response": {
        "status": 204
      }
    }
  ]
}
