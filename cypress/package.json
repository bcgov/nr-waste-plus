{
  "name": "cypress",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "report:md": "node scripts/generate-github-summary.js",
    "report:clean": "rm -rf reports/mochawesome/* reports/a11y/* reports/lighthouse/*",
    "precy:run": "npm run report:clean",
    "cy:run": "cypress run --reporter junit --reporter-options mochaFile=result.xml,toConsole=true",
    "postcy:run": "npm run report:md",
    "precy:run:md": "npm run report:clean",
    "cy:run:md": "MOCHAWESOME_REPORT=true cypress run --browser chrome --reporter mochawesome --reporter-options reportDir=reports/mochawesome,overwrite=false,html=false,json=true --config \"baseUrl=https://nr-waste-plus-test-frontend.apps.silver.devops.gov.bc.ca/\"",
    "postcy:run:md": "npm run report:md",
    "precy:run:local": "npm run report:clean",
    "cy:run:local": "cypress run --reporter junit --reporter-options mochaFile=result.xml,toConsole=true --config \"baseUrl=http://localhost:3000\"",
    "postcy:run:local": "npm run report:md",
    "precy:run:lighthouse:local": "npm run report:clean",
    "cy:run:lighthouse:local": "MOCHAWESOME_REPORT=true cypress run --browser chrome --spec \"cypress/e2e/lighthouse_examples.feature\" --reporter mochawesome --reporter-options reportDir=reports/mochawesome,overwrite=false,html=false,json=true --config \"baseUrl=http://localhost:3000\"",
    "postcy:run:lighthouse:local": "npm run report:md",
    "precy:run:lighthouse": "npm run report:clean",
    "cy:run:lighthouse": "MOCHAWESOME_REPORT=true cypress run --browser chrome --spec \"cypress/e2e/lighthouse_examples.feature\" --reporter mochawesome --reporter-options reportDir=reports/mochawesome,overwrite=false,html=false,json=true --config \"baseUrl=https://nr-waste-plus-test-frontend.apps.silver.devops.gov.bc.ca/\"",
    "postcy:run:lighthouse": "npm run report:md",
    "precy:run:md:local": "npm run report:clean",
    "cy:run:md:local": "MOCHAWESOME_REPORT=true cypress run --browser chrome --reporter mochawesome --reporter-options reportDir=reports/mochawesome,overwrite=false,html=false,json=true --config \"baseUrl=http://localhost:3000\"",
    "postcy:run:md:local": "npm run report:md",
    "cy:open:local": "cypress open --config \"baseUrl=http://localhost:3000\"",
    "cy:open:remote": "cypress open --config \"baseUrl=https://nr-waste-plus-test-frontend.apps.silver.devops.gov.bc.ca/\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@cypress/webpack-preprocessor": "^7.0.0",
    "@testing-library/cypress": "^10.1.0",
    "@types/node": "^25.5.0",
    "axe-core": "^4.11.0",
    "cypress": "^15.0.0",
    "cypress-audit": "^1.1.0",
    "cypress-axe": "^1.7.0",
    "cypress-real-events": "^1.14.0",
    "dotenv": "^17.3.1",
    "lighthouse": "^12.8.2",
    "mochawesome": "^7.1.4",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.4",
    "webpack": "^5.81.0"
  },
  "cypress-cucumber-preprocessor": {
    "nonGlobalStepDefinitions": true
  },
  "overrides": {
    "dompurify@<3.3.2": "^3.3.2",
    "serialize-javascript": "^7.0.3",
    "lodash@^4.0.0": "^4.17.23",
    "qs": "6.15.0",
    "form-data": "4.0.5",
    "tmp": "^0.2.4",
    "undici": ">=6.21.0",
    "shelljs": {
      "glob": "13.0.6"
    },
    "module-lookup-amd": {
      "glob": "13.0.6"
    }
  }
}
